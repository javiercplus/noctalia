# Template file for 'noctalia'
pkgname=noctalia
version=5.0.0
revision=3
build_style=meson
hostmakedepends="pkg-config meson ninja git wayland-devel wayland-protocols"
makedepends="wayland-devel wayland-protocols libepoxy-devel MesaLib-devel libglvnd-devel
 cairo-devel pango-devel fontconfig-devel freetype-devel harfbuzz-devel
 libxkbcommon-devel pipewire-devel libcurl-devel pam-devel libwebp-devel
 basu-devel sdbus-c++-devel polkit-devel librsvg-devel libqalculate-devel
 libxml2-devel jemalloc-devel wireplumber-devel"
short_desc="Noctalia - Wayland compositor and desktop environment"
maintainer="JavierC"
license="MIT"
homepage="https://github.com/noctalia-dev/noctalia"
distfiles="https://github.com/javiercplus/noctalia/releases/download/${version}/noctalia-main.tar.gz"
checksum="1df4488e0874d683b3cdda97e9ee77ccde481f87d5a09e68039b1244ee9ab4d7"

# Forzar arquitectura compatible (x86_64 genérico)
CFLAGS="-march=x86-64 -mtune=generic -O2 -pipe"
CXXFLAGS="-march=x86-64 -mtune=generic -O2 -pipe"

do_configure() {
	cd ${wrksrc}
	meson setup build \
		--prefix=/usr \
		--libdir=/usr/lib \
		--buildtype=release \
		-Dcpp_args="${CXXFLAGS}" \
		-Dc_args="${CFLAGS}"
}

do_build() {
	cd ${wrksrc}
	ninja -C build
}

do_install() {
	cd ${wrksrc}
	DESTDIR=${DESTDIR} ninja -C build install
}
